---
import type { HTMLAttributes } from "astro/types";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-6 sm:py-5",
      "border-t border-border",
      "flex flex-col items-center gap-3 sm:flex-row sm:justify-between",
    ]}
  >
    <!-- Logo + copyright -->
    <div class="flex items-center gap-2 text-sm" style="color: var(--text-muted);">
      <a
        href="https://feed-flow.app"
        target="_blank"
        rel="noopener noreferrer"
        class="font-semibold hover:opacity-80 transition-opacity"
        style="color: var(--accent);"
      >
        FeedFlow
      </a>
      <span>·</span>
      <span>© {currentYear}</span>
      <span>·</span>
      <span>Todos os direitos reservados</span>
    </div>

    <!-- Links -->
    <nav class="flex items-center gap-4 text-sm" style="color: var(--text-muted);">
      <a
        href="https://feed-flow.app"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-accent transition-colors"
      >
        Produto
      </a>
      <a
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-accent transition-colors"
        aria-label="Feed RSS"
      >
        RSS
      </a>
    </nav>
  </div>
</footer>
