---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">

    <!-- Hero -->
    <section id="hero" class:list={["pt-10 pb-8", "border-b border-border"]}>
      <p class="text-sm font-medium mb-3" style="color: var(--accent);">
        Blog FeedFlow
      </p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 leading-tight" style="color: var(--foreground); letter-spacing: -0.02em;">
        Tudo sobre feeds de produtos<br class="hidden sm:block" /> e anúncios de catálogo
      </h1>
      <p class="text-base max-w-xl" style="color: var(--text-secondary); line-height: 1.7;">
        Dicas práticas, tutoriais e estratégias para lojistas que anunciam no Meta Ads, Google Shopping, TikTok e Pinterest.
      </p>
    </section>

    <!-- Artigos em destaque -->
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-10 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-xl font-semibold mb-1" style="color: var(--foreground);">Em destaque</h2>
          <p class="text-sm mb-4" style="color: var(--text-muted);">Artigos selecionados pela equipe</p>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <!-- Artigos recentes -->
    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-6">
          <h2 class="text-xl font-semibold mb-1" style="color: var(--foreground);">Artigos recentes</h2>
          <p class="text-sm mb-4" style="color: var(--text-muted);">Últimas publicações</p>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <!-- Ver todos -->
    <div class="my-10 flex justify-center">
      <a
        href="/posts/"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold border transition-colors"
        style="border-color: var(--border); color: var(--foreground); background: var(--bg-surface);"
        onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"
        onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--foreground)'"
      >
        Ver todos os artigos
        <IconArrowRight class="inline-block rtl:-rotate-180" width={16} height={16} />
      </a>
    </div>

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
